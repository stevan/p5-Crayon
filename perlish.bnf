# ============================================================================

# Perl Grammar — Language-Level Specification (v5)

# ============================================================================

#

# FORMAT: Chalk::Bootstrap BNF with | alternates

#

# PURPOSE:

# Clean description of Perl 5.42+ syntax for documentation and compilation

# via Chalk’s Earley parser with composite semirings.

#

# DESIGN:

# - Nonterminals name concepts a Perl programmer would recognize

# - Semicolons separate statements; commas separate list elements

# - Keyword synonyms collapsed into token class patterns

# - Optional trailing elements use nullable nonterminals

# - Operator precedence enforced by semiring, not grammar nesting

# - Sub-languages (regex, interpolation, heredocs) handled separately

#

# COMPANION PIECES:

# 1. Builtin Signature Table — arity and argument types from perldoc

# (determines call shape: nullary, unary, list, block-first, indirect)

# 2. String Interpolation Sub-grammar

# 3. Regex Sub-grammar

# 4. Heredoc Preprocessor

# 5. Precedence Table — for Precedence semiring

#

# SEMIRINGS:

# Precedence — operator precedence and associativity

# Type — builtin argument types and list/scalar context

# SPPF — parse forest construction

# Structural — {} disambiguation (block vs hash constructor)

# CST — concrete syntax tree / comment preservation

#

# ============================================================================

# ============================================================================

# PATTERNS

# ============================================================================

# Whitespace

%WS% = /[ \t\r\n]+/
%COMMENT% = /#[^\n]*/

# Identifiers

%IDENT% = /[a-zA-Z_]\w*/
%QUALIFIED_IDENT% = /[a-zA-Z_]\w*(?:::[a-zA-Z_]\w*)*/
%LABEL% = /[a-zA-Z_]\w*\s*:/

# Numeric literals

%INTEGER% = /(?:0[xX][0-9a-fA-F](?:_?[0-9a-fA-F])*|0[bB][01](?:_?[01])*|0[oO]?[0-7](?:_?[0-7])*|[0-9](?:_?[0-9])*)/
%FLOAT% = /[0-9](?:_?[0-9])*.(?:[0-9](?:_?[0-9])*)?(?:[eE][+-]?[0-9]+)?/
%VERSION% = /v?[0-9]+(?:.[0-9]+){2,}/

# String literals

%SINGLE_QUOTED% = /’(?:[^’\]|\.)*’/
%DOUBLE_QUOTED% = /”(?:[^”\]|\.)*”/
%BACKTICK% = /`(?:[^`\]|\.)*`/

# Regex

%REGEX_BODY% = /(?:[^/\]|\.)*+/
%REGEX_FLAGS% = /[msixpodualngcer]*/

# Operators

%ASSIGN_OP% = /(?:**|//||||&&|[.+-*/%&|^]|<<?|>>?)=/
%POW_OP% = /**/
%MUL_OP% = /[*/%]|x(?![a-zA-Z_])/
%ADD_OP% = /[+-]/
%CONCAT_OP% = /.(?!.)/
%SHIFT_OP% = /<<|>>/
%NUM_CMP_OP% = /(?:<=>|[<>]=?|[!=]=)/
%STR_CMP_OP% = /(?:eq|ne|lt|gt|le|ge|cmp)\b/
%MATCH_OP% = /[!=]~/
%BIT_AND_OP% = /&.?(?![&=])/
%BIT_OR_OP% = /[|^].?(?!=)/
%RANGE_OP% = /...?/

# Keyword token classes

%IF_KW% = /\b(?:if|unless)\b/
%WHILE_KW% = /\b(?:while|until)\b/
%FOR_KW% = /\b(?:for|foreach)\b/
%MODIFIER_KW% = /\b(?:if|unless|while|until|for|foreach|when)\b/
%LOOP_CONTROL_KW% = /\b(?:last|next|redo)\b/
%DECLARATOR_KW% = /\b(?:my|our|state|local)\b/
%USE_KW% = /\b(?:use|no)\b/

# Builtin arity is resolved by Type semiring consulting the signature table,

# not by grammar-level token classification. All builtins match %IDENT%.

# ============================================================================

# §1  WHITESPACE

# ============================================================================

Gap ->
| GapElem Gap

GapElem -> %WS% | %COMMENT%

Ws -> GapElem
|  GapElem Gap

# ============================================================================

# §2  PROGRAM STRUCTURE

# ============================================================================

Program -> Gap StatementSequence Gap

# Semicolons are separators, not terminators

StatementSequence ->
|  Statement
|  StatementSequence Gap ‘;’ Gap StatementSequence

FullStatement -> Statement
|  %LABEL% Gap Statement
|  %LABEL% Gap FullStatement

# ============================================================================

# §3  STATEMENTS

# ============================================================================

Statement -> Declaration | CompoundStatement | ExpressionStatement | ‘…’

ExpressionStatement -> Expression
|  Expression Ws PostfixModifier

PostfixModifier -> %MODIFIER_KW% Ws Expression

# ============================================================================

# §4  COMPOUND STATEMENTS

# ============================================================================

CompoundStatement -> ConditionalStatement | WhileLoop | CStyleForLoop
|  ForeachLoop | GivenStatement | WhenStatement
|  DefaultStatement | TryCatchStatement | DeferStatement
|  Block OptionalContinue | PhaserBlock
|  PackageBlock | ClassBlock
|  SubroutineDefinition | MethodDefinition

# Conditional (if/unless share identical syntax via %IF_KW%)

ConditionalStatement -> %IF_KW% Gap ParenExpr Gap Block ElseChain

ElseChain ->
|  Gap ‘elsif’ Gap ParenExpr Gap Block ElseChain
|  Gap ‘else’ Gap Block

# While / Until

WhileLoop -> %WHILE_KW% Gap ParenExpr Gap Block OptionalContinue

OptionalContinue ->
|  Gap ‘continue’ Gap Block

# C-style for

CStyleForLoop -> ‘for’ Gap ‘(’ Gap OptionalExpression Gap ‘;’ Gap OptionalExpression Gap ‘;’ Gap OptionalExpression Gap ‘)’ Gap Block

# Foreach iteration

ForeachLoop -> %FOR_KW% Ws IteratorVariable Gap ParenExpr Gap Block OptionalContinue
|  %FOR_KW% Gap ParenExpr Gap Block OptionalContinue

IteratorVariable -> ‘my’ Ws ScalarVariable
|  ‘my’ Gap ‘(’ Gap IteratorVariableList Gap ‘)’
|  ScalarVariable
|  ‘my’ Ws ’' Gap Variable
|  ’' Gap Variable

IteratorVariableList -> Variable
|  IteratorVariableList Gap ‘,’ Gap Variable
|  IteratorVariableList Gap ‘,’ Gap ’' Gap Variable

# Given / When / Default

GivenStatement -> ‘given’ Gap ParenExpr Gap Block
WhenStatement -> ‘when’ Gap ParenExpr Gap Block
DefaultStatement -> ‘default’ Gap Block

# Exception handling

TryCatchStatement -> ‘try’ Gap Block Gap ‘catch’ Gap CatchVariable Gap Block OptionalFinally

CatchVariable ->
|  ‘(’ Gap ScalarVariable Gap ‘)’

OptionalFinally ->
|  Gap ‘finally’ Gap Block

# Defer

DeferStatement -> ‘defer’ Gap Block

# Phaser

PhaserBlock -> ‘ADJUST’ Gap Block

# ============================================================================

# §5  DECLARATIONS

# ============================================================================

Declaration -> UseDeclaration | VariableDeclaration | FieldDeclaration
|  PackageDeclaration | ClassDeclaration
|  SubroutineDeclaration | MethodDeclaration | FormatDeclaration

# Use / No

UseDeclaration -> %USE_KW% Ws ModuleName
|   %USE_KW% Ws ModuleName Ws ImportList

ModuleName -> %QUALIFIED_IDENT%
|  %VERSION%
|  %QUALIFIED_IDENT% Ws %VERSION%

ImportList -> ExpressionList

# Package

PackageDeclaration -> ‘package’ Ws %QUALIFIED_IDENT% OptionalVersion
PackageBlock -> ‘package’ Ws %QUALIFIED_IDENT% OptionalVersion Gap Block

# Class

ClassDeclaration -> ‘class’ Ws %QUALIFIED_IDENT% OptionalVersion OptionalAttributes
ClassBlock -> ‘class’ Ws %QUALIFIED_IDENT% OptionalVersion OptionalAttributes Gap Block

# Subroutine

SubroutineDeclaration -> ‘sub’ Ws SubroutineName OptionalPrototype OptionalAttributes
|  %DECLARATOR_KW% Ws ‘sub’ Ws SubroutineName

SubroutineDefinition -> ‘sub’ Ws SubroutineName OptionalPrototype OptionalAttributes Gap SubroutineBody
|  %DECLARATOR_KW% Ws ‘sub’ Ws SubroutineName Gap SubroutineBody

SubroutineName -> %IDENT% | %QUALIFIED_IDENT%

SubroutineBody -> Block | Signature Gap Block

# Method

MethodDeclaration -> ‘method’ Ws %IDENT%
MethodDefinition -> ‘method’ Ws %IDENT% OptionalAttributes Gap SubroutineBody

# Field

FieldDeclaration -> ‘field’ Ws Variable OptionalAttributes OptionalDefault

OptionalDefault ->
|  Gap ‘=’ Gap Expression

# Variable (my / our / state / local)

VariableDeclaration -> %DECLARATOR_KW% Ws Variable OptionalAttributes
|  %DECLARATOR_KW% Ws ‘(’ Gap VariableList Gap ‘)’
|  %DECLARATOR_KW% Ws ’' Gap Variable OptionalAttributes

VariableList -> Variable
|   VariableList Gap ‘,’ Gap Variable

# Format (mostly deprecated)

FormatDeclaration -> ‘format’ Ws %IDENT% | ‘format’

# Optional trailing elements (nullable — free with Earley)

OptionalVersion ->
|  Ws %VERSION%

OptionalPrototype ->
|  Gap Prototype

OptionalAttributes ->
|  Gap AttributeList

Prototype -> ‘(’ Gap %IDENT% Gap ‘)’ | ‘(’ Gap ‘)’

AttributeList -> ‘:’ Gap Attribute
|   ‘:’ Gap Attribute Gap AttributeList

Attribute -> %IDENT%
|  %IDENT% ‘(’ Gap Expression Gap ‘)’

# Signatures

Signature -> ‘(’ Gap ‘)’ | ‘(’ Gap SignatureParams Gap ‘)’

SignatureParams -> SignatureParam
|  SignatureParams Gap ‘,’ Gap SignatureParam
|  SignatureParams Gap ‘,’

SignatureParam -> SignatureScalar | SignatureSlurpy

SignatureScalar -> ‘$’ Gap %IDENT%
|  ‘$’ Gap %IDENT% Gap ‘=’ Gap Expression
|  ‘:’ Gap ‘$’ Gap %IDENT%
|  ‘:’ Gap ‘$’ Gap %IDENT% Gap ‘=’ Gap Expression
|  ‘$’

SignatureSlurpy -> ‘@’ Gap %IDENT% | ‘@’
|  ‘%’ Gap %IDENT% | ‘%’

# ============================================================================

# §6  EXPRESSIONS

# ============================================================================

Expression -> Atom | UnaryExpression | PostfixExpression
|  BinaryExpression | TernaryExpression
|  AssignmentExpression
|  LoopControlExpression

# Atoms

Atom -> Literal | Variable | ParenExpr | ‘(’ Gap ‘)’
|  Constructor | AnonymousSub | DoExpression
|  CallExpression | MethodCall
|  Subscript | Dereference | %IDENT%

# Unary

UnaryExpression -> ‘-’ Gap Expression | ‘+’ Gap Expression
|  ‘!’ Gap Expression | ‘~’ Gap Expression
|  ‘not’ Ws Expression | ’' Gap Expression
|  ‘++’ Gap Expression | ‘–’ Gap Expression

# Postfix

PostfixExpression -> Expression Gap ‘++’ | Expression Gap ‘–’

# Binary (all precedence resolved by semiring)

BinaryExpression -> Expression Gap %POW_OP% Gap Expression
|  Expression Gap %MUL_OP% Gap Expression
|  Expression Gap %ADD_OP% Gap Expression
|  Expression Gap %CONCAT_OP% Gap Expression
|  Expression Gap %SHIFT_OP% Gap Expression
|  Expression Gap %NUM_CMP_OP% Gap Expression
|  Expression Gap %STR_CMP_OP% Gap Expression
|  Expression Gap %MATCH_OP% Gap Expression
|  Expression Gap %BIT_AND_OP% Gap Expression
|  Expression Gap %BIT_OR_OP% Gap Expression
|  Expression Gap %RANGE_OP% Gap Expression
|  Expression Gap ‘&&’ Gap Expression
|  Expression Gap ‘||’ Gap Expression
|  Expression Gap ‘//’ Gap Expression
|  Expression Gap ‘and’ Gap Expression
|  Expression Gap ‘or’ Gap Expression
|  Expression Gap ‘xor’ Gap Expression
|  Expression Gap ‘isa’ Gap Expression
|  ComparisonChain

ComparisonChain -> Expression Gap %NUM_CMP_OP% Gap Expression Gap %NUM_CMP_OP% Gap Expression
|  ComparisonChain Gap %NUM_CMP_OP% Gap Expression

# Ternary

TernaryExpression -> Expression Gap ‘?’ Gap Expression Gap ‘:’ Gap Expression

# Assignment

AssignmentExpression -> Expression Gap ‘=’ Gap Expression
|  Expression Gap %ASSIGN_OP% Gap Expression

# ============================================================================

# §7  EXPRESSION LISTS

# ============================================================================

# Commas are separators, not operators

ExpressionList -> Expression
|   ExpressionList Gap ‘,’ Gap Expression
|   ExpressionList Gap ‘=>’ Gap Expression
|   ExpressionList Gap ‘,’

OptionalExpression ->
|  Expression

OptionalExpressionList ->
|  ExpressionList

# ============================================================================

# §8  CALLS

# ============================================================================

#

# All function and builtin invocations share the same grammar structure.

# Builtin arity (nullary, named unary, list op, block-first) is resolved

# by the Type semiring consulting the signature table, not by grammar rules.

#

# Example: `time + 1` produces two parses:

# 1. CallExpression(time, +1)    — bare call with unary-plus arg

# 2. BinaryExpression(time, +, 1) — nullary call plus addition

# The Type semiring prunes parse 1 because `time` is nullary.

#

# Call shapes:

# name(args)           — parens call (unambiguous)

# name args            — bare call (arity from signature table)

# name                 — no-arg call

# name BLOCK args      — block-first (map, grep, sort, etc.)

# name BLOCK           — block-only

# name INDIRECT args   — indirect object (print STDERR “hi”)

# &name / &name(args)  — sigiled call (bypasses prototypes)

CallExpression -> %IDENT% Gap ‘(’ Gap OptionalExpressionList Gap ‘)’
|   %QUALIFIED_IDENT% Gap ‘(’ Gap OptionalExpressionList Gap ‘)’
|   %IDENT% Ws ExpressionList
|   %IDENT%
|   %IDENT% Gap Block Ws ExpressionList
|   %IDENT% Gap Block
|   %IDENT% Ws IndirectObject Ws ExpressionList
|   ‘&’ Gap %IDENT%
|   ‘&’ Gap %IDENT% Gap ‘(’ Gap OptionalExpressionList Gap ‘)’
|   ‘&’ Gap %QUALIFIED_IDENT%
|   ‘&’ Gap %QUALIFIED_IDENT% Gap ‘(’ Gap OptionalExpressionList Gap ‘)’
|   ‘require’
|   ‘require’ Ws Expression

IndirectObject -> ScalarVariable | Block | %IDENT%

# Loop control and return are expression-level, not call-shaped

LoopControlExpression -> %LOOP_CONTROL_KW%
|  %LOOP_CONTROL_KW% Ws %IDENT%
|  ‘goto’ Ws Expression
|  ‘goto’ Ws ‘&’ Gap %IDENT%


# ============================================================================

# §9  METHOD CALLS

# ============================================================================

MethodCall -> Expression Gap ‘->’ Gap MethodName Gap ‘(’ Gap OptionalExpressionList Gap ‘)’
|  Expression Gap ‘->’ Gap MethodName
|  Expression Gap ‘->’ Gap ScalarVariable Gap ‘(’ Gap OptionalExpressionList Gap ‘)’
|  Expression Gap ‘->’ Gap ScalarVariable
|  Expression Gap ‘->’ Gap ‘&’ Gap SubroutineName Gap ‘(’ Gap OptionalExpressionList Gap ‘)’
|  Expression Gap ‘->’ Gap ‘&’ Gap SubroutineName

MethodName -> %IDENT% | %QUALIFIED_IDENT%

# ============================================================================

# §10  DO EXPRESSIONS

# ============================================================================

DoExpression -> ‘do’ Gap Block | ‘do’ Ws Expression

# ============================================================================

# §11  SUBSCRIPTS AND DEREFERENCES

# ============================================================================

Subscript -> Expression Gap ‘[’ Gap Expression Gap ‘]’
|  Expression Gap ‘{’ Gap Expression Gap ‘}’
|  Expression Gap ‘->’ Gap ‘[’ Gap Expression Gap ‘]’
|  Expression Gap ‘->’ Gap ‘{’ Gap Expression Gap ‘}’
|  Expression Gap ‘->’ Gap ‘(’ Gap OptionalExpressionList Gap ‘)’
|  ‘@’ Gap Expression Gap ‘[’ Gap ExpressionList Gap ‘]’
|  ‘@’ Gap Expression Gap ‘{’ Gap ExpressionList Gap ‘}’
|  ‘%’ Gap Expression Gap ‘[’ Gap ExpressionList Gap ‘]’
|  ‘%’ Gap Expression Gap ‘{’ Gap ExpressionList Gap ‘}’
|  ‘(’ Gap ExpressionList Gap ‘)’ Gap ‘[’ Gap ExpressionList Gap ‘]’

Dereference -> Expression Gap ‘->’ Gap ‘@’ Gap ‘*’
|  Expression Gap ‘->’ Gap ‘%’ Gap ’*’
|  Expression Gap ‘->’ Gap ‘$’ Gap ‘*’
|  Expression Gap ‘->’ Gap ‘&’ Gap ’*’
|  Expression Gap ‘->’ Gap ‘*’ Gap ’*’
|  Expression Gap ‘->’ Gap ‘$#’ Gap ‘*’

# ============================================================================

# §12  CONSTRUCTORS

# ============================================================================

Constructor -> ‘[’ Gap OptionalExpressionList Gap ‘]’
|  ‘{’ Gap OptionalExpressionList Gap ‘}’

AnonymousSub -> ‘sub’ Gap SubroutineBody
|   ‘sub’ Gap Prototype Gap SubroutineBody
|   ‘sub’ Gap AttributeList Gap SubroutineBody
|   ‘method’ Gap SubroutineBody
|   ‘method’ Gap AttributeList Gap SubroutineBody

# ============================================================================

# §13  VARIABLES

# ============================================================================

Variable -> ScalarVariable | ArrayVariable | HashVariable
|  GlobVariable | ArrayLengthVariable

ScalarVariable -> ‘$’ Gap VariableName
|  ‘$’ Gap ‘{’ Gap Expression Gap ‘}’
|  ‘$’ Gap ScalarVariable

ArrayVariable -> ‘@’ Gap VariableName
|  ‘@’ Gap ‘{’ Gap Expression Gap ‘}’
|  ‘@’ Gap ScalarVariable

HashVariable -> ‘%’ Gap VariableName
|  ‘%’ Gap ‘{’ Gap Expression Gap ‘}’
|  ‘%’ Gap ScalarVariable

GlobVariable -> ‘*’ Gap VariableName
|  ’*’ Gap ‘{’ Gap Expression Gap ‘}’

ArrayLengthVariable -> ‘$#’ Gap VariableName
|  ‘$#’ Gap ‘{’ Gap Expression Gap ‘}’

VariableName -> %IDENT% | %QUALIFIED_IDENT% | SpecialVariableName

SpecialVariableName -> ‘_’ | %INTEGER%

# ============================================================================

# §14  LITERALS

# ============================================================================

Literal -> NumericLiteral | StringLiteral | RegexLiteral
|  QuotedWords | HeredocLiteral
|  ‘undef’ | ‘**FILE**’ | ‘**LINE**’ | ‘**PACKAGE**’

NumericLiteral -> %INTEGER% | %FLOAT%

StringLiteral -> %SINGLE_QUOTED% | %DOUBLE_QUOTED% | %BACKTICK% | %VERSION%

RegexLiteral -> ‘/’ Gap %REGEX_BODY% Gap ‘/’ Gap %REGEX_FLAGS%
|  ‘m’ Gap ‘/’ Gap %REGEX_BODY% Gap ‘/’ Gap %REGEX_FLAGS%
|  ‘qr’ Gap ‘/’ Gap %REGEX_BODY% Gap ‘/’ Gap %REGEX_FLAGS%
|  ‘s’ Gap ‘/’ Gap %REGEX_BODY% Gap ‘/’ Gap %REGEX_BODY% Gap ‘/’ Gap %REGEX_FLAGS%
|  ‘tr’ Gap ‘/’ Gap %REGEX_BODY% Gap ‘/’ Gap %REGEX_BODY% Gap ‘/’ Gap %REGEX_FLAGS%
|  ‘y’ Gap ‘/’ Gap %REGEX_BODY% Gap ‘/’ Gap %REGEX_BODY% Gap ‘/’ Gap %REGEX_FLAGS%

QuotedWords -> ‘qw’ Gap ‘(’ Gap WordList Gap ‘)’
WordList -> %IDENT% | %IDENT% Ws WordList

HeredocLiteral -> ‘q’ Gap ‘{’ Gap %SINGLE_QUOTED% Gap ‘}’
|  ‘qq’ Gap ‘{’ Gap %DOUBLE_QUOTED% Gap ‘}’

# ============================================================================

# §15  HELPERS

# ============================================================================

ParenExpr -> ‘(’ Gap Expression Gap ‘)’
Block -> ‘{’ Gap StatementSequence Gap ‘}’
